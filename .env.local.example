# BudgetBuddy environment variables — TEMPLATE
#
# 1. Copy this file to `.env.local` (which is gitignored).
# 2. Fill in the values.
# 3. Restart `npm run dev` so Vite picks up the new env.
#
# Only variables prefixed with VITE_ are exposed to the client bundle.

# --- App ---
VITE_APP_URL=http://localhost:5173


# --- AI (optional) ---
# When VITE_USE_REAL_AI=true and VITE_GEMINI_API_KEY is set, the app will call
# the real Google Gemini API for categorisation, insights and receipt parsing
# instead of the deterministic mock.
# WARNING: a Vite SPA exposes env vars in the client bundle. Only enable this
# for local development. For production, proxy AI calls through a backend.
VITE_USE_REAL_AI=false
VITE_GEMINI_API_KEY=
# Model name. Defaults to gemini-2.5-flash (the legacy gemini-1.5-flash was
# retired in 2026 and now returns 404 on the v1beta endpoint).
# Options: gemini-2.5-flash | gemini-2.5-pro | gemini-2.0-flash
VITE_GEMINI_MODEL=gemini-2.5-flash


# --- Supabase ---
# When BOTH of these are set, the app reads/writes from your Supabase project
# (Auth, Postgres, Storage, Realtime). Otherwise it falls back to a
# localStorage-only "demo mode" that works completely offline.
#
# 1. In your Supabase project, run the entire `supabase/schema.sql` once.
# 2. Copy the values below from Project Settings → API.
#
# Project URL looks like:   https://xxxxxxxx.supabase.co
# anon (public) key starts with: eyJhbGciOi...
#
# The SERVICE ROLE key MUST NEVER be put in a Vite app — it bypasses RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
